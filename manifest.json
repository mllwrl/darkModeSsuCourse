{
    "manifest_version": 3,
    "name": "SSU Dark Mode",
    "version": "1.1",
    "description": "Dark theme for course.sgu.ru - by mllwrl",
    "author": "mllwrl",
    "homepage_url": "https://github.com/mllwrl",
    "browser_specific_settings": {
        "gecko": {
            "id": "ssu-dark-mode@student.sgu.ru",
            "strict_min_version": "109.0"
        }
    },
    "permissions": [
        "storage"
    ],
    "action": {
        "default_icon": "icon.png",
        "default_title": "SSU Dark Mode Pro",
        "default_popup": "popup.html"
    },
    "icons": {
        "128": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://course.sgu.ru/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "style.css"
            ],
            "matches": [
                "https://course.sgu.ru/*"
            ]
        }
    ]
}